# copy this file to .env.local and fill in values. dont commit .env.local.

# iron-session needs 32+ chars or login breaks
SESSION_SECRET=replace-me-with-32-chars-minimum-okaaay

# one password per role (pick your own strings)
CSHELPER_HELPER_PASSWORD=
CSHELPER_TRUSTED_PASSWORD=
CSHELPER_ADMIN_PASSWORD=

# optional discord hooks
DISCORD_WEBHOOK_URL=
DISCORD_BACKUP_WEBHOOK_URL=

# sqlite file (relative to project root unless you use absolute path)
DATABASE_URL=file:./data/cshelper.db

# optional: same value in Authorization: Bearer <token> for POST /api/backup (cron)
BACKUP_CRON_SECRET=

# optional Cloudflare R2 — DB still stores /uploads/… and /maps/…; app resolves full URLs with R2_PUBLIC_BASE_URL
# Create bucket + API token (R2 read/write) in Cloudflare dashboard; enable public URL (r2.dev or custom domain).
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
